{
  "$schema": "https://opencode.ai/config.json",
  "experimental": { "batch_tool": true },
  "plugin": [
    "opencode-pty",
    "@mohak34/opencode-notifier@latest",
    "@franlol/opencode-md-table-formatter@0.0.6"
  ],
  "username": "aki",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--usage-statistics=false"
      ],
      "enabled": false
    },
    "chrome-devtools-headless": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--usage-statistics=false",
        "--headless=true"
      ]
    }
  },
  "provider": {
    "zai-coding-plan": {
      "options": {
        "apiKey": "{env:ZLM_API_KEY}"
      }
    },
    "minimax": {
      "options": {
        "apiKey": "{env:MINIMAX_API_KEY}"
      }
    }
  },
  "lsp": {
    "typescript": {
      "command": [
        "sh",
        "-c",
        "npx --no-install typescript-language-server --stdio || typescript-language-server --stdio"
      ],
      "extensions": [".ts", ".tsx", ".js", ".jsx"]
    }
  },
  "permission": {
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow",
      "~/.config/opencode/gsd-core/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow",
      "~/.config/opencode/gsd-core/*": "allow"
    }
  }
}
