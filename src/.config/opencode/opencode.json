{
  "$schema": "https://opencode.ai/config.json",
  "experimental": { "batch_tool": true },
  "plugin": [
    "@paflopes/opencode-qwen-auth",
    "opencode-pty",
    "@mohak34/opencode-notifier@latest",
    "@franlol/opencode-md-table-formatter@0.0.6"
  ],
  "username": "aki",
  "keybinds": {
    "app_exit": "ctrl+q",
    "session_export": "<leader>x",
    "editor_open": "ctrl+e",
    "session_new": "<leader>n",
    "session_list": "ctrl+l,<leader>l",
    "session_timeline": "ctrl+/",
    "session_compact": "none",
    "messages_page_up": "pageup",
    "messages_page_down": "pagedown",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_next": "none",
    "messages_previous": "none",
    "messages_copy": "<leader>y",
    "messages_undo": "<leader>u",
    "messages_redo": "<leader>r",
    "messages_last_user": "none",
    "messages_toggle_conceal": "<leader>h",
    "model_list": "<leader>m",
    "model_cycle_favorite": "ctrl+f",
    "model_cycle_favorite_reverse": "ctrl+b",
    "variant_cycle": "ctrl+t",
    "command_list": "ctrl+p",
    "agent_cycle": "tab",
    "agent_cycle_reverse": "shift+tab",
    "input_clear": "ctrl+q,<leader>c",
    "input_paste": "<leader>v",
    "input_submit": "return",
    "input_newline": "shift+return,ctrl+return,alt+return,ctrl+j",
    "terminal_suspend": "ctrl+z"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--usage-statistics=false"
      ],
      "enabled": false
    },
    "chrome-devtools-headless": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--usage-statistics=false",
        "--headless=true"
      ]
    }
  },
  "provider": {
    "zai-coding-plan": {
      "options": {
        "apiKey": "{env:ZLM_API_KEY}"
      }
    },
    "minimax": {
      "options": {
        "apiKey": "{env:MINIMAX_API_KEY}"
      }
    }
  },
  "server": { "hostname": "0.0.0.0", "mdns": true }
}
